# ============================================================================
# PitchMD Environment Configuration Template
# ============================================================================
# IMPORTANT: This file contains NO secrets. All secrets must come from:
#   - Azure Key Vault (production)
#   - Azure App Service configuration (staging/prod)
#   - Local .env.local file (development only - never commit)
#
# For development:
#   1. Copy this file to .env.local
#   2. Fill in actual values in .env.local
#   3. Never commit .env.local to git
#
# For production (Azure):
#   - Use Azure Key Vault for all secrets
#   - Use App Service "Configuration" panel for app settings
#   - Never pass secrets via environment variables in IaC

# ============================================================================
# FEATURE FLAGS (Non-secret - OK to set via App Service)
# ============================================================================

# Authentication mode: "stub" (demo) or "oauth" (production)
FEATURE_AUTH=stub

# Analytics enabled: "on" or "off"
FEATURE_ANALYTICS=on

# Demo mode (only used if FEATURE_AUTH=stub)
DEMO_MODE=true
DEMO_USERNAME=demo@demo.local

# ============================================================================
# SNOWFLAKE - Non-Secret Configuration
# ============================================================================

# Snowflake account identifier (format: xy12345.region)
# This is PUBLIC, no secret
SNOWFLAKE_ACCOUNT=hj98757.us-east-1

# Snowflake warehouse and database (PUBLIC, no secret)
SNOWFLAKE_WAREHOUSE=CORTEX_WH
SNOWFLAKE_DATABASE=CORTEX_TESTING
SNOWFLAKE_SCHEMA=CORTEX_TESTING.PUBLIC

# Snowflake username (often not secret - service account email)
# If sensitive, move to Key Vault
SNOWFLAKE_USERNAME=SRI_APP_SERVICE

# Cortex API prewarm timeout in milliseconds (PUBLIC, no secret)
CORTEX_PREWARM_TIMEOUT_MS=5000

# ============================================================================
# SECRETS - MUST COME FROM AZURE KEY VAULT (Never commit actual values)
# ============================================================================
# These are loaded from Azure Key Vault at runtime
# DO NOT set them in code, .env files, or environment variables

# Session encryption key (from Key Vault)
# In Key Vault secret name: session-secret
# Min 32 characters, generated via: node -e "console.log(require('crypto').randomBytes(40).toString('hex'))"
SESSION_SECRET=*** FROM AZURE KEY VAULT ***

# Snowflake authentication (from Key Vault)
# Option: Personal Access Token preferred for service accounts
# In Key Vault secret name: snowflake-pat
SNOWFLAKE_PAT=*** FROM AZURE KEY VAULT ***

# Alternative: Password (if using username/password auth)
# In Key Vault secret name: snowflake-password
# SNOWFLAKE_PASSWORD=*** FROM AZURE KEY VAULT ***

# Anthropic Claude API key (from Key Vault)
# In Key Vault secret name: anthropic-api-key
ANTHROPIC_API_KEY=*** FROM AZURE KEY VAULT ***

# Groq Whisper API key (from Key Vault)
# In Key Vault secret name: groq-api-key
GROQ_API_KEY=*** FROM AZURE KEY VAULT ***

# Tavus video avatar API key (from Key Vault)
# In Key Vault secret name: tavus-api-key
TAVUS_API_KEY=*** FROM AZURE KEY VAULT ***

# Tavus persona ID (optional - from Key Vault if sensitive)
# In Key Vault secret name: tavus-persona-id
# TAVUS_PERSONA_ID=*** FROM AZURE KEY VAULT ***

# Anam physician context API key (from Key Vault)
# In Key Vault secret name: anam-api-key
ANAM_API_KEY=*** FROM AZURE KEY VAULT ***

# Compliance admin emails (can be in App Service config or Key Vault)
# In Key Vault secret name: compliance-admin-emails
# Format: email1@domain.com,email2@domain.com
COMPLIANCE_ADMIN_EMAILS=*** FROM AZURE KEY VAULT ***

# Demo password (from Key Vault for production, .env.local for dev)
# In Key Vault secret name: demo-password
DEMO_PASSWORD=*** FROM AZURE KEY VAULT ***

# ============================================================================
# AZURE-SPECIFIC CONFIGURATION
# ============================================================================

# Azure Key Vault URL (set in App Service → Configuration)
# Format: https://your-keyvault-name.vault.azure.net/
AZURE_KEYVAULT_URL=https://your-keyvault-name.vault.azure.net/

# Azure Managed Identity (automatic, no config needed)
# App Service uses system-assigned managed identity to access Key Vault

# ============================================================================
# NODE ENVIRONMENT
# ============================================================================

NODE_ENV=development
# For production: NODE_ENV=production
