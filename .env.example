# ============================================================================
# PitchMD Environment Configuration
# ============================================================================
# Copy this file to .env.local and fill in actual values for development
# For production, use your platform's secrets manager:
#   - Azure: Key Vault
#   - AWS: Secrets Manager or Parameter Store
#   - GCP: Secret Manager
#   - Kubernetes: Secrets

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Authentication mode: "stub" (demo) or "oauth" (production)
FEATURE_AUTH=stub

# Analytics enabled: "on" or "off"
FEATURE_ANALYTICS=on

# Demo mode credentials (only used if FEATURE_AUTH=stub)
DEMO_MODE=true
DEMO_USERNAME=demo@demo.local
DEMO_PASSWORD=demo

# ============================================================================
# SESSION & AUTHENTICATION
# ============================================================================

# Session encryption key - MUST be at least 32 characters
# Generate: node -e "console.log(require('crypto').randomBytes(40).toString('hex'))"
SESSION_SECRET=your-random-32-char-min-secret-here

# Admin email list (comma-separated) - for compliance dashboard access
COMPLIANCE_ADMIN_EMAILS=admin@example.com,compliance@example.com

# ============================================================================
# SNOWFLAKE (Database & Vector Search)
# ============================================================================

# Snowflake account identifier (format: xy12345.region)
SNOWFLAKE_ACCOUNT=hj98757.us-east-1

# Snowflake authentication - choose one approach:

# Option A: Personal Access Token (PAT) - recommended for service accounts
SNOWFLAKE_USERNAME=SRI_APP_SERVICE
SNOWFLAKE_PAT=your-snowflake-pat-token-here

# Option B: Username/Password (less secure, not recommended)
# SNOWFLAKE_USERNAME=your_username
# SNOWFLAKE_PASSWORD=your_password

# Snowflake warehouse and database
SNOWFLAKE_WAREHOUSE=CORTEX_WH
SNOWFLAKE_DATABASE=CORTEX_TESTING
SNOWFLAKE_SCHEMA=CORTEX_TESTING.PUBLIC

# Snowflake role (optional - uses default if not specified)
# SNOWFLAKE_ROLE=CORTEX_TESTING_ROLE

# Cortex API prewarm timeout (milliseconds, optional)
CORTEX_PREWARM_TIMEOUT_MS=5000

# ============================================================================
# EXTERNAL APIs - LLM & AI
# ============================================================================

# Anthropic Claude API key
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ============================================================================
# EXTERNAL APIs - SPEECH & AVATAR
# ============================================================================

# Groq Whisper API key (Speech-to-Text)
# Get from: https://console.groq.com/
GROQ_API_KEY=gsk_your-groq-key-here

# Tavus video avatar API key
# Get from: https://console.tavus.io/
TAVUS_API_KEY=your-tavus-key-here

# Tavus persona ID (optional - auto-created if not provided)
# TAVUS_PERSONA_ID=your-persona-id-here

# ============================================================================
# EXTERNAL APIs - CONTEXTUAL FEATURES
# ============================================================================

# Anam (physician contextual data) API key
# Get from: https://anam.ai/
ANAM_API_KEY=your-anam-key-here

# ============================================================================
# NODE ENVIRONMENT
# ============================================================================

# Standard Node.js environment
NODE_ENV=development
# For production: NODE_ENV=production
